# LLM 配置（复制此文件为 .env 并填入实际值）
# .env 已被 .gitignore 忽略，不会提交到仓库

API_BASE=https://api.openai.com/v1
API_KEY=sk-your-api-key-here
MODEL=gpt-4o-mini

# 监听目录列表，逗号分隔（绝对路径）
WATCH_PATHS=/path/to/posts1,/path/to/posts2

# 最短内容长度（字符数），低于此值的文件跳过，防止不完整的文件过早打标
# MIN_CONTENT_LENGTH=200

# 草稿标记，逗号分隔。文件头部 500 字符内包含任一标记则跳过
# DRAFT_MARKERS=<!-- draft -->,<!-- wip -->
